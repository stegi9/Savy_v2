# Docker Compose Environment Variables Template
# Copy this to .env in root directory

# MySQL Configuration
MYSQL_ROOT_PASSWORD=rootpassword_change_me
MYSQL_DATABASE=savy_db
MYSQL_USER=savy_user
MYSQL_PASSWORD=Ciao1806@

# Redis Configuration
REDIS_PASSWORD=redis_secret_change_me

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google Gemini API
GOOGLE_API_KEY=your_gemini_api_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@savy.app

# Sentry Error Monitoring
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id

# Environment
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://10.0.2.2:8000

# Bank Integration (Salt Edge) - Use mock for now
SALT_EDGE_APP_ID=mock
SALT_EDGE_SECRET=mock

# Affiliate APIs
AMAZON_ASSOCIATE_TAG=your-amazon-tag
BOOKING_AFFILIATE_ID=your-booking-id

secrets/
credentials/

# ============================================================================
# DOCUMENTATION & TEMPORARY
# ============================================================================

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Backup files
*.bak
*.backup

# Archive files
*.zip
*.tar.gz
*.rar

# ============================================================================
# CI/CD
# ============================================================================

# GitHub Actions cache
.github/actions-runner/

# Terraform (if using)
.terraform/
*.tfstate
*.tfstate.backup

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

# Sentry
.sentryclirc

# ============================================================================
# NOTES
# ============================================================================
# Assicurati SEMPRE che:
# 1. .env files non siano mai committati
# 2. Firebase config files siano in .gitignore
# 3. SSL certificates non siano esposti
# 4. Database dumps locali siano ignorati
# 5. API keys hardcoded vengano rimosse prima del commit
# ============================================================================

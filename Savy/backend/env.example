# =============================================================================
# SAVY BACKEND - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# DATABASE (MySQL)
# =============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=savy_db

# =============================================================================
# AI / LLM (Google Gemini)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_characters_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://10.0.2.2:8000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# EMAIL SERVICE (for password reset, verification)
# =============================================================================
EMAIL_FROM=noreply@savy.app
EMAIL_FROM_NAME=Savy - Personal Finance Coach
SENDGRID_API_KEY=

# =============================================================================
# REDIS (for caching and rate limiting)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# CELERY (for background jobs)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# SENTRY (for error monitoring - Optional)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# FIREBASE (for push notifications)
# =============================================================================
FIREBASE_CREDENTIALS_PATH=

# =============================================================================
# BANK INTEGRATION (Salt Edge)
# =============================================================================
SALTEDGE_APP_ID=your_saltedge_app_id
SALTEDGE_SECRET=your_saltedge_secret
SALTEDGE_BASE_URL=https://www.saltedge.com/api/v6

# =============================================================================
# AFFILIATE APIs (Optional - will use mock data if not set)
# =============================================================================
# Amazon Product Advertising API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=savy-21
AMAZON_COUNTRY=IT

# Awin Affiliate Network
AWIN_API_TOKEN=
AWIN_PUBLISHER_ID=

# Booking.com Affiliate
BOOKING_AFFILIATE_ID=
BOOKING_API_KEY=

# =============================================================================
# PRODUCTION ONLY
# =============================================================================
# MySQL Root Password (for Docker)
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# =============================================================================
# SAVY BACKEND - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (MySQL - Required)
# -----------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=savy_db
MYSQL_ROOT_PASSWORD=your_root_password  # For Docker

# -----------------------------------------------------------------------------
# AI (Google Gemini - Required)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# -----------------------------------------------------------------------------
# AUTHENTICATION (JWT - Required)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=generate_a_secure_random_string_here

# -----------------------------------------------------------------------------
# SALT EDGE (Open Banking - Required for bank sync)
# -----------------------------------------------------------------------------
SALTEDGE_APP_ID=your_saltedge_app_id
SALTEDGE_SECRET=your_saltedge_secret

# -----------------------------------------------------------------------------
# REDIS (Caching - Optional, improves performance)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# AFFILIATE APIS (Optional - Uses mock data if not set)
# -----------------------------------------------------------------------------

# Amazon Product Advertising API
# Get from: https://affiliate-program.amazon.it/
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=savy-21

# Awin Affiliate Network
# Get from: https://www.awin.com/
AWIN_API_TOKEN=
AWIN_PUBLISHER_ID=

# Booking.com Partner API
# Get from: https://partners.booking.com/
BOOKING_AFFILIATE_ID=
BOOKING_API_KEY=

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://10.0.2.2:8000
